{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "rules": {
    "typescript/no-explicit-any": "warn",
    "typescript/no-unnecessary-type-assertion": "error"
  },
  "overrides": [
    {
      "files": [
        "apps/**/src/routes/**/*.ts",
        "apps/**/src/routes/**/*.tsx",
        "apps/**/src/components/**/*.ts",
        "apps/**/src/components/**/*.tsx",
        "apps/**/src/lib/**/*.ts",
        "apps/**/src/lib/**/*.tsx"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@nxus/db/server"],
                "message": "Do not import @nxus/db/server in client code. Use local .server.ts wrappers with dynamic imports."
              },
              {
                "group": ["@nxus/workbench/server"],
                "message": "Do not import @nxus/workbench/server in client code. Use local .server.ts wrappers with dynamic imports."
              }
            ]
          }
        ]
      }
    }
  ],
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".output",
    "**/*.test.ts",
    "**/__tests__/**"
  ]
}
